# Supabase
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
# Password de la base de datos (solo si se usa conexión directa, opcional)
SUPABASE_DB_PASSWORD=your-database-password

# Voyage AI (embeddings)
VOYAGE_API_KEY=your-voyage-ai-api-key

# Anthropic (Claude Sonnet 4.6)
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-sonnet-4-6

# Google OAuth
# Tras autorizar la primera vez se generan los archivos:
#   secrets/google_credentials.json   (desde Google Cloud Console, lo descargas tú)
#   secrets/google_token.json          (se crea automáticamente en el primer login)
GOOGLE_CREDENTIALS_PATH=secrets/google_credentials.json
GOOGLE_TOKEN_PATH=secrets/google_token.json
