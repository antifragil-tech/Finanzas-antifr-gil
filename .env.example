# ──────────────────────────────────────────────────────────
# Alsari Capital OS — Variables de entorno
# ──────────────────────────────────────────────────────────
# Copia este archivo a `.env` y rellena con tus valores reales.
# NUNCA commitees `.env` con valores reales. Solo este archivo
# (`.env.example`) va al repositorio.
# ──────────────────────────────────────────────────────────

# ─── Supabase ──────────────────────────────────────────────
# Obtén estas claves en: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here

# SERVICE ROLE: solo para Edge Functions / backend. NUNCA en cliente.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Anthropic API (Claude in apps) ────────────────────────
# Si en algún módulo se llama directamente a la API de Claude.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── Resend (emails transaccionales) ───────────────────────
# Opcional. Para reportes automáticos, alertas, etc.
RESEND_API_KEY=re_your-key-here

# ─── Entorno ───────────────────────────────────────────────
NODE_ENV=development

# ─── Branding / Build ──────────────────────────────────────
NEXT_PUBLIC_APP_NAME="Alsari Capital OS"
NEXT_PUBLIC_APP_VERSION="0.1.0"

# ─── Demo local (escenario B) ──────────────────────────────
# SOLO para demo local sin backend. Ponlo en `apps/host/.env.local` (NO se
# commitea). Salta el gate de auth del host para ver el OS + Reservas sin
# Supabase. Se IGNORA automáticamente si NODE_ENV=production. Nunca en producción.
#   ANTIFRAGIL_DEMO_MODE=true
# En modo demo, las NEXT_PUBLIC_SUPABASE_* pueden ser placeholders dummy
# (p. ej. http://demo.local) — no se hace ninguna llamada real a Supabase.
